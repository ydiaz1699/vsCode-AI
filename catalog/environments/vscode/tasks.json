{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "PlatformIO: Build",
            "type": "shell",
            "command": "pio run",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$platformio",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "PlatformIO: Upload",
            "type": "shell",
            "command": "pio run --target upload",
            "group": "build",
            "problemMatcher": "$platformio",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "PlatformIO: Monitor",
            "type": "shell",
            "command": "pio device monitor",
            "group": "test",
            "problemMatcher": "$platformio",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "PlatformIO: Clean",
            "type": "shell",
            "command": "pio run --target clean",
            "group": "build",
            "problemMatcher": "$platformio",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "PlatformIO: Full Deploy",
            "type": "shell",
            "command": "pio run --target upload && pio device monitor",
            "group": "build",
            "problemMatcher": "$platformio",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "PlatformIO: Test",
            "type": "shell",
            "command": "pio test",
            "group": "test",
            "problemMatcher": "$platformio",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "PlatformIO: Check",
            "type": "shell",
            "command": "pio check",
            "group": "test",
            "problemMatcher": "$platformio",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
