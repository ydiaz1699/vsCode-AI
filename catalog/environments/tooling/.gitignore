# =============================================================================
# PlatformIO Standard .gitignore
# =============================================================================

# PlatformIO build directory
.pio/

# VS Code generated files
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Sensitive files
secrets.h
credentials.h

# Build artifacts
*.bin
*.elf
*.map
*.hex
*.o
*.d

# Compilation database
compile_commands.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
venv/
.env

# IDE files
*.swp
*.swo
*~

# Logs
*.log
